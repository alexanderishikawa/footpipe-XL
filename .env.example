# Pipeline providers (CI / local default: fake)
OCR_PROVIDER=fake
LLM_PROVIDER=fake

# Live providers (M8+) — copy to .env and fill in secrets
# OCR_PROVIDER=azure
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-key
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# Data stores (Compose typically sets these)
DATABASE_URL=postgresql+psycopg://pipeline:pipeline@postgres:5432/pipeline
REDIS_URL=redis://redis:6379/0

# S3-compatible object store (MinIO in Compose)
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_BUCKET=footpipe
OBJECT_STORE_ACCESS_KEY=minioadmin
OBJECT_STORE_SECRET_KEY=minioadmin
OBJECT_STORE_REGION=us-east-1

# Paperless-ngx
PAPERLESS_URL=http://paperless:8000
PAPERLESS_TOKEN=

# Optional landing webhook (poller is primary)
# LANDING_HOOK_SECRET=

# Pipeline guardrails
SPLIT_MIN_CONFIDENCE=0.6
MAX_PAGES_PER_BATCH=200
MAX_PAGES_PER_DAY=500

# API
# API_HOST=0.0.0.0
# API_PORT=8080
