# Pipeline providers (CI / local default: fake)
OCR_PROVIDER=fake
LLM_PROVIDER=fake

# Live providers (M8+) — leave unset until ready
# OCR_PROVIDER=azure
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-key
# Azure F0 (free): max 4 MB and 2 pages per OCR request — defaults match F0.
# Azure S0 (paid): set AZURE_OCR_CHUNK_PAGES=25 for fewer API calls.
# AZURE_OCR_CHUNK_PAGES=2
# AZURE_OCR_CHUNK_MAX_BYTES=3500000
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key

# Data stores (Compose typically sets these)
DATABASE_URL=postgresql+psycopg://pipeline:pipeline@postgres:5432/pipeline
REDIS_URL=redis://redis:6379/0

# S3-compatible object store (MinIO in Compose)
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_BUCKET=footpipe
OBJECT_STORE_ACCESS_KEY=minioadmin
OBJECT_STORE_SECRET_KEY=minioadmin
OBJECT_STORE_REGION=us-east-1

# Paperless-ngx
PAPERLESS_URL=http://paperless:8000
PAPERLESS_TOKEN=

# v1.1 metadata sync (enrich.run + PaperlessArchive.sync_metadata)
# METADATA_DATE_MIN_CONF=0.7
# METADATA_ORIGINATOR_MIN_CONF=0.6
# PAPERLESS_BOOTSTRAP_TYPES=true
# PAPERLESS_CONTENT_DATE_FIELD_NAME=Content Date

# Optional landing webhook (poller is primary)
# LANDING_HOOK_SECRET=

# Pipeline guardrails
SPLIT_MIN_CONFIDENCE=0.6
MAX_PAGES_PER_BATCH=200
MAX_PAGES_PER_DAY=500

# API
# API_HOST=0.0.0.0
# API_PORT=8080
